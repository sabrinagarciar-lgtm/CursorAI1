# Snyk configuration for ShopEase 8_1
# https://docs.snyk.io/snyk-cli/configure-the-snyk-cli

version: v1.0.0

# Scan project roots relative to this file
scan:
  - path: ../../frontend
    type: npm
    policy: .snyk
  - path: ../../backend
    type: pip
    file: requirements.txt

severity-threshold: high

# Quality target: 0 critical vulnerabilities
fail-on:
  critical: true
  high: false

report:
  format: json
  output: ../results/security/snyk-report.json
