# Copy to .env and fill secrets (never commit .env).

# -----------------------------------------------------------------------------
# GCP / Cloud SQL (example: app DB user + encoded password for DATABASE_URL)
# With Cloud SQL Auth Proxy listening on localhost:5432, use DATABASE_URL — it
# takes priority over unix_socket PG* vars. Encode special chars in passwords
# inside DATABASE_URL (`!` → `%21`; see urllib.parse.quote_plus).
#
# DATABASE_URL=postgresql+psycopg://appuser2:PASSWORD_ENCODED_HERE@127.0.0.1:5432/blog_platform_sab
# PGUSER=appuser2
# PGPASSWORD=CLEAR_TEXT_PASSWORD_HERE
# PGDATABASE=blog_platform_sab

# -----------------------------------------------------------------------------
# Target: PostgreSQL 18.3 on Google Cloud SQL
# Instance connection name (PROJECT:REGION:INSTANCE):
CLOUDSQL_INSTANCE_CONNECTION_NAME=gd-gcp-gridu-genai:us-central1:appuser1

# --- Local dev: Homebrew Postgres (macOS — no Docker) ---
# brew install postgresql@18
# export PATH="$(brew --prefix postgresql@18)/bin:$PATH"
# brew services start postgresql@18
# createdb blog_platform || true
# DATABASE_URL=postgresql+psycopg://YOUR_MAC_LOGIN@127.0.0.1:5432/blog_platform

# --- Local dev: Docker Compose — only if `docker compose` exists (docker-compose.yml) ---
# docker compose up -d postgres
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/blog_platform

# Optional: Postgres DB Flask connects to before auto-creating DATABASE_URL's database (`flask init-db`).
# POSTGRES_MAINTENANCE_DATABASE=postgres

# --- Option A: Cloud SQL Auth Proxy (local / CI) ---
# Terminal 1: cloud-sql-proxy "gd-gcp-gridu-genai:us-central1:appuser1"
# DATABASE_URL listens on localhost (default proxy port 5432):
DATABASE_URL=postgresql+psycopg://YOUR_DB_USER:YOUR_PASSWORD@127.0.0.1:5432/YOUR_DATABASE

# --- Option B: Unix socket from Cloud Run / GCE VM with mounted /cloudsql ---
# Omit DATABASE_URL and use:
CLOUD_SQL_CONNECT_MODE=unix_socket
PGUSER=YOUR_DB_USER
PGPASSWORD=YOUR_PASSWORD
PGDATABASE=YOUR_DATABASE
# Optional override of "/cloudsql/PROJECT:REGION:INSTANCE":
# CLOUDSQL_UNIX_SOCKET_HOST=/cloudsql/gd-gcp-gridu-genai:us-central1:appuser1

# --- Option C: private IP / VPC direct (no proxy) ---
# DATABASE_URL=postgresql+psycopg://YOUR_DB_USER:YOUR_PASSWORD@10.x.x.x:5432/YOUR_DATABASE

SECRET_KEY=
JWT_SECRET_KEY=

# -----------------------------------------------------------------------------
# Rate limiting (Flask-Limiter) and HTTPS / reverse proxy (see README "Security")
# RATELIMIT_STORAGE_URI=memory://
# RATELIMIT_DEFAULT=200 per day;50 per hour
# RATELIMIT_AUTH=20 per minute
# TRUST_PROXY_HEADERS=1
# TALISMAN_FORCE_HTTPS=0

# -----------------------------------------------------------------------------
# Redis cache (Flask-Caching) — run Redis on the host (brew/apt), not via this repo's Docker Compose
# REDIS_URL=redis://127.0.0.1:6379/0
# CACHE_POSTS_LIST_TTL=60
# CACHE_POSTS_DETAIL_TTL=120
# CACHE_POSTS_ENABLED=true
# CACHE_DISABLED=0
