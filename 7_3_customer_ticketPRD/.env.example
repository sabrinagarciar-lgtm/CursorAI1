# Flask
FLASK_ENV=development
SECRET_KEY=change-me

# JWT (use ≥32 random bytes/chars so PyJWT HS256 emits no insecure-key warnings)
JWT_SECRET_KEY=replace-with-a-strong-secret-at-least-32-chars-long

# Database (PostgreSQL recommended for production)
DATABASE_URL=sqlite:///instance/support.db

# Comma-separated browser origins allowed to call /api/* (Flask-CORS). Development defaults in
# config.py already include http://localhost:5173 and http://127.0.0.1:5173 if unset — override here if needed.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: enforce HTTPS redirects in production (Talisman)
TALISMAN_FORCE_HTTPS=false
